<view class="page">
  <view class="category-head">
    <text class="category-head-icon">{{category.icon}}</text>
    <view>
      <text class="category-head-name">{{category.name}}</text>
      <text class="category-head-desc">{{category.desc}} · {{lessons.length}} 节</text>
    </view>
  </view>

  <view class="lesson-list">
    <view
      class="lesson-card card"
      wx:for="{{lessons}}"
      wx:key="day_number"
      data-day="{{item.day_number}}"
      bindtap="openLesson"
    >
      <text class="lesson-meta">Day {{item.day_number}}</text>
      <text class="lesson-title">{{item.title}}</text>
      <text class="lesson-excerpt">{{item.content}}</text>
    </view>
  </view>
</view>
