page {
  min-height: 100%;
  background: #faf7f0;
  color: #2c2c2c;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #26302a;
  font-size: 34rpx;
  font-weight: 700;
}

.brand-mark {
  display: flex;
  width: 52rpx;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #e9f0e5;
  color: #5a7358;
  font-size: 30rpx;
}

.muted {
  color: #8b8581;
}

.card {
  border: 1rpx solid #eadfce;
  border-radius: 20rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 28rpx rgba(84, 70, 55, 0.06);
}

.soft-card {
  border: 1rpx solid rgba(124, 154, 122, 0.18);
  border-radius: 20rpx;
  background: rgba(124, 154, 122, 0.08);
}

.section-title {
  margin: 42rpx 0 20rpx;
  color: #2c2c2c;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #8b8581;
  font-size: 24rpx;
}

.primary-button {
  display: flex;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #6f8f73;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.secondary-button {
  display: flex;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d9cbb8;
  border-radius: 18rpx;
  background: #fffdf8;
  color: #3a3a34;
  font-size: 28rpx;
  font-weight: 600;
}

.pill {
  display: inline-flex;
  min-height: 44rpx;
  align-items: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: rgba(124, 154, 122, 0.12);
  color: #5a7358;
  font-size: 23rpx;
  font-weight: 600;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.category-card {
  width: calc((100% - 18rpx) / 2);
  min-height: 164rpx;
  padding: 24rpx;
}

.category-icon {
  display: block;
  margin-bottom: 14rpx;
  font-size: 42rpx;
}

.category-name {
  display: block;
  color: #2c2c2c;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.category-desc {
  display: block;
  margin-top: 8rpx;
  color: #8b8581;
  font-size: 23rpx;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.lesson-card {
  padding: 24rpx;
}

.lesson-meta {
  color: #5a7358;
  font-size: 23rpx;
  font-weight: 700;
}

.lesson-title {
  display: block;
  margin-top: 10rpx;
  color: #2c2c2c;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.28;
}

.lesson-excerpt {
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  color: #766f6a;
  font-size: 25rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}
