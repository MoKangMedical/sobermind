# SoberMind 清醒日课 — Environment Variables
# 复制此文件为 .env.local 并填入真实值

# DeepSeek API Key — 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# 神经男声音频生成参数
EDGE_TTS_VOICE=zh-CN-YunyangNeural
EDGE_TTS_RATE=-7%
EDGE_TTS_PITCH=-2Hz
AUDIO_SAMPLE_RATE=24000
AUDIO_BITRATE=48k
LESSON_AUDIO_EXTENSION=mp3
LESSON_AUDIO_VOICE_LABEL=YunyangNeural 男声

# JWT 签名密钥 — 生产环境请换为强随机字符串
JWT_SECRET=change-me-to-a-strong-random-string

# 应用 URL（Vercel 部署后改为 https://your-app.vercel.app）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 可选：会员线索后端地址，用于 Web 会员页同步提交意向
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787

# 可选：示例后端会员线索落盘位置
MEMBERSHIP_LEADS_FILE=.runtime/membership-leads.jsonl
